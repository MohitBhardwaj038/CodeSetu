# ─── Server ───────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB Atlas ────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_NAME=code-setu
# Judge0 — cloud (no Docker) or local after: docker compose up -d
JUDGE0_API_URL=https://ce.judge0.com/submissions/batch
# JUDGE0_API_URL=http://localhost:2358/submissions/batch

# ─── JWT ──────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Gmail (App Password) ─────────────────────
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
# or: GMAIL_PASS=your_16_char_app_password

# ─── OTP ──────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ─── CORS ─────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Leave empty to allow all (not recommended for production)
CLIENT_ORIGIN=http://localhost:5173

